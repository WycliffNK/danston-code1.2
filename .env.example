# Google Sheets API — service account flow.
# Create a service account in Google Cloud, enable the Sheets API,
# share the target spreadsheet with the service account email,
# then paste the JSON key fields below (escape newlines in the private key as \n).
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Assessments!A:N
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Transactional email — assessment submissions are emailed via Resend.
# Get an API key at https://resend.com/api-keys.
RESEND_API_KEY=
# Where submissions are sent. Defaults to danstunmugarura@gmail.com if unset.
ASSESSMENT_NOTIFY_EMAIL=danstunmugarura@gmail.com
# Verified sender (https://resend.com/domains). Until a domain is verified,
# leave blank to use the Resend sandbox (onboarding@resend.dev), which only
# delivers to the Resend account owner's email. e.g. "Code 1 <hello@code1.one>"
ASSESSMENT_FROM_EMAIL=
